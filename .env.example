# === WATI ===
WATI_API_ENDPOINT=https://live-mt-server.wati.io
WATI_TENANT_ID=your_tenant_id
WATI_API_TOKEN=your_wati_bearer_token

# === Webhook ===
WEBHOOK_SECRET=your_random_secret_here

# === LLM ===
ANTHROPIC_API_KEY=sk-ant-xxx
GEMINI_API_KEY=
LLM_PROVIDER=gemini

# === Feishu ===
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_APP_TOKEN=your_feishu_app_token
FEISHU_TABLE_CUSTOMERS=your_table_id
FEISHU_TABLE_FOLLOWUP=your_table_id

# === Auto Reply ===
AUTO_REPLY_ENABLED=true
AUTO_REPLY_COOLDOWN=30
AUTO_REPLY_MAX_PER_HOUR=10
AUTO_REPLY_DELAY=5
AUTO_REPLY_HUMAN_PAUSE=1800
KNOWLEDGE_BASE_PATH=data/knowledge_base.md

# === HubSpot ===
HUBSPOT_ACCESS_TOKEN=pat-xxx
HUBSPOT_ENABLED=false

# === Obsidian Sync ===
OBSIDIAN_SYNC_URL=https://your-obsidian-sync.example.com
OBSIDIAN_SYNC_SECRET=change-me-to-a-random-secret
OBSIDIAN_SYNC_ENABLED=false

# === App ===
LOG_LEVEL=INFO
DAILY_ANALYSIS_HOUR=23
DAILY_ANALYSIS_MINUTE=0
PIPELINE_INTERVAL_HOURS=1
